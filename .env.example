# Julia Fonseca — Environment Variables
# Copy this file to .env.local and fill in the values.
# See DRIVE-SETUP.md for step-by-step instructions.

# Google Service Account JSON (entire key file content, single line)
# Get this from Google Cloud Console → IAM → Service Accounts → Keys
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Google Drive Folder ID
# This is the ID from the URL of Julia's shared folder:
# https://drive.google.com/drive/folders/THIS_IS_THE_ID
GOOGLE_DRIVE_FOLDER_ID=
